{
  "name": "@sudobility/svgr_app",
  "private": true,
  "version": "1.0.75",
  "type": "module",
  "scripts": {
    "dev": "bun run process:static && vite",
    "build": "bun run process:static && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md,css}\"",
    "typecheck": "tsc -b",
    "process:static": "curl -sL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/process-static-files.ts -o /tmp/process-static-files.ts && bunx tsx /tmp/process-static-files.ts",
    "localize": "SCRIPT=$(mktemp) && curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/localize_batch.cjs -o $SCRIPT && node $SCRIPT ./public/locales https://api.whisperly.dev/api/v1/translate/jie9cytr/svgr --word-limit 40 && rm -f $SCRIPT && prettier . --write",
    "localized": "node scripts/localization_verify.cjs",
    "verify": "bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@revenuecat/purchases-js": "^1.26.0",
    "@sudobility/auth-components": "^1.0.10",
    "@sudobility/auth_lib": "^0.0.68",
    "@sudobility/building_blocks": "^0.0.210",
    "@sudobility/components": "^5.0.57",
    "@sudobility/consumables_client": "^0.0.15",
    "@sudobility/consumables_pages": "^0.0.20",
    "@sudobility/design": "^1.1.28",
    "@sudobility/devops-components": "^2.0.19",
    "@sudobility/di": "^1.5.52",
    "@sudobility/di_web": "^0.1.165",
    "@sudobility/entity_client": "^0.0.33",
    "@sudobility/seo_lib": "^0.0.9",
    "@sudobility/subscription-components": "^1.0.31",
    "@sudobility/subscription_lib": "^0.0.38",
    "@sudobility/svgr_client": "^1.0.26",
    "@sudobility/svgr_lib": "^0.0.23",
    "@sudobility/svgr_types": "^1.0.16",
    "@sudobility/types": "^1.9.61",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.4.0",
    "i18next": "^25.8.7",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jspdf": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "svg2pdf.js": "^2.7.0",
    "tailwind-merge": "^3.4.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
